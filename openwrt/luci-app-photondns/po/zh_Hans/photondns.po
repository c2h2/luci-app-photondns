msgstr "阿里 DNS（UDP 223.5.5.5）"

msgid "Tencent DNSPod (UDP 119.29.29.29)"
msgstr "腾讯 DNSPod（UDP 119.29.29.29）"

msgid "114DNS (UDP)"
msgstr "114DNS（UDP）"

msgid "AliDNS (DoT)"
msgstr "阿里 DNS（DoT）"

msgid "DNSPod (DoT)"
msgstr "腾讯 DNSPod（DoT）"

msgid "Google (DoT)"
msgstr "谷歌（DoT）"

msgid "Cloudflare (DoT)"
msgstr "Cloudflare（DoT）"

msgid "Google (DoH)"
msgstr "谷歌（DoH）"

msgid "Quad9 (UDP)"
msgstr "Quad9（UDP）"

msgid "131072 (~50 MB)"
msgstr "131072（约 50 MB）"

msgid "16384 (~6 MB)"
msgstr "16384（约 6 MB）"

msgid "262144 (~100 MB)"
msgstr "262144（约 100 MB）"

msgid "32768 (~13 MB)"
msgstr "32768（约 13 MB）"

