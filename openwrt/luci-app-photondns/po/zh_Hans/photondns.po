msgstr "8192（约 3 MB）"

msgid "Could not change service state."
msgstr "无法更改服务状态。"

msgid "Could not change service state: "
msgstr "无法更改服务状态："

msgid "DoH Path"
msgstr "DoH 路径"

msgid "DoH Port"
msgstr "DoH 端口"

msgid "DoH Server"
msgstr "DoH 服务器"

msgid "DoH TLS Certificate"
msgstr "DoH TLS 证书"

msgid "DoH TLS Key"
msgstr "DoH TLS 私钥"

msgid "Listen on TCP"
msgstr "监听 TCP"

msgid "Listen on UDP"
msgstr "监听 UDP"

msgid "Loading..."
msgstr "加载中..."

msgid "Maximum number of cached responses (sharded LRU). RAM shown is the ceiling when the cache is fully populated (~400 B/entry); actual use grows lazily."
msgstr "缓存应答的最大条数（分片 LRU）。所示内存为缓存全满时的上限（每条约 400 B）；实际占用按需增长。"

msgid "Path to a PEM certificate chain; leave empty when behind a reverse proxy"
msgstr "PEM 证书链路径；置于反向代理之后时留空"

msgid "Path to the PEM private key"
msgstr "PEM 私钥路径"

msgid "Serve DNS over TCP on the listen port (needed for large answers)"
msgstr "在监听端口上提供 TCP DNS 服务（大应答需要）"

msgid "Serve DNS-over-HTTPS (RFC 8484) on the DoH port. Runs plain HTTP unless a certificate is set below - put a TLS reverse proxy (Caddy/nginx) in front, or set cert + key to serve HTTPS directly"
msgstr "在 DoH 端口上提供 DNS-over-HTTPS（RFC 8484）服务。未在下方设置证书时仅提供明文 HTTP——可在前端部署 TLS 反向代理（Caddy/nginx），或设置证书和私钥以直接提供 HTTPS"

msgid "Serve classic DNS over UDP on the listen port"
msgstr "在监听端口上提供传统 UDP DNS 服务"

msgid "Service disabled"
msgstr "服务已禁用"

msgid "Service enabled"
msgstr "服务已启用"

msgid "Turn Off"
msgstr "关闭"

msgid "Turn On"
msgstr "开启"

msgid "Update failed to start:"
msgstr "更新启动失败："

