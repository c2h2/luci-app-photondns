msgstr "命中率"

msgid "Hits / Misses"
msgstr "命中 / 未命中"

msgid "Stale served"
msgstr "过期应答次数"

msgid "Prefetches"
msgstr "预取次数"

msgid "Evictions"
msgstr "淘汰次数"

msgid "Upstream Servers"
msgstr "上游服务器"

msgid "Group"
msgstr "分组"

msgid "Upstream"
msgstr "上游"

msgid "State"
msgstr "状态"

